import java.util.ArrayList;
import java.util.Iterator;
import java.util.Scanner;

// Abstract superclass
abstract class Room {
    protected int roomNumber;
    protected double basePricePerNight;
    protected boolean isBooked;

    public Room(int roomNumber, double basePricePerNight) {
        this.roomNumber = roomNumber;
        this.basePricePerNight = basePricePerNight;
        this.isBooked = false;
    }

‎    // كل غرفة تحسب السعر بطريقة مختلفة — polymorphism
    public abstract double calculatePrice(int nights);

‎    // عمليات مشتركة
    public boolean book() {
        if (isBooked) return false;
        isBooked = true;
        return true;
    }

    public boolean cancel() {
        if (!isBooked) return false;
        isBooked = false;
        return true;
    }

    public boolean isBooked() {
        return isBooked;
    }

    public int getRoomNumber() {
        return roomNumber;
    }

    public double getBasePricePerNight() {
        return basePricePerNight;
    }

    public void displayInfo() {
        System.out.println("Room #" + roomNumber + " | Base price/night: $" + basePricePerNight +
                           " | Booked: " + (isBooked ? "Yes" : "No"));
    }
}

// Subclass: Single room
class SingleRoom extends Room {
    public SingleRoom(int roomNumber, double basePricePerNight) {
        super(roomNumber, basePricePerNight);
    }

    @Override
    public double calculatePrice(int nights) {
‎        // بسيطة: السعر = base * nights
        return basePricePerNight * nights;
    }

    @Override
    public void displayInfo() {
        System.out.print("[Single] ");
        super.displayInfo();
    }
}

// Subclass: Double room
class DoubleRoom extends Room {
    private double serviceFeePerNight = 10.0; // مثال رسوم خدمة

    public DoubleRoom(int roomNumber, double basePricePerNight) {
        super(roomNumber, basePricePerNight);
    }

    @Override
    public double calculatePrice(int nights) {
‎        // السعر = (base + service) * nights
        return (basePricePerNight + serviceFeePerNight) * nights;
    }

    @Override
    public void displayInfo() {
        System.out.print("[Double] ");
        super.displayInfo();
    }
}

// Subclass: Suite room
class SuiteRoom extends Room {
    private double luxuryFee = 50.0;

    public SuiteRoom(int roomNumber, double basePricePerNight) {
        super(roomNumber, basePricePerNight);
    }

    @Override
    public double calculatePrice(int nights) {
        double total = (basePricePerNight * nights) + luxuryFee;
‎        // خصم لو الإقامة طويلة
        if (nights >= 7) {
            total *= 0.9; // 10% تخفيض للأقامات >= 7 ليالي
        }
        return total;
    }

    @Override
    public void displayInfo() {
        System.out.print("[Suite] ");
        super.displayInfo();
    }
}

// Guest class (encapsulation)
class Guest {
    private String name;
    private String idNumber;

    public Guest(String name, String idNumber) {
        this.name = name;
        this.idNumber = idNumber;
    }

    public String getName() {
        return name;
    }

    public String getIdNumber() {
        return idNumber;
    }

    public void displayGuest() {
        System.out.println("Guest: " + name + " | ID: " + idNumber);
    }
}

// Booking class links Guest with Room
class Booking {
    private static int counter = 1;
    private int bookingId;
    private Guest guest;
    private Room room;
    private int nights;

    public Booking(Guest guest, Room room, int nights) {
        this.bookingId = counter++;
        this.guest = guest;
        this.room = room;
        this.nights = nights;
    }

    public int getBookingId() {
        return bookingId;
    }

    public int getRoomNumber() {
        return room.getRoomNumber();
    }

    public double getTotalPrice() {
        return room.calculatePrice(nights);
    }

    public void displayBooking() {
        System.out.println("Booking ID: " + bookingId);
        guest.displayGuest();
        System.out.println("Room #: " + room.getRoomNumber() + " | Nights: " + nights);
        System.out.printf("Total price: $%.2f\n", getTotalPrice());
    }
}

// Booking system using ArrayList
class BookingSystem {
    private ArrayList<Room> rooms;
    private ArrayList<Booking> bookings;

    public BookingSystem() {
        rooms = new ArrayList<>();
        bookings = new ArrayList<>();
    }

    public void addRoom(Room r) {
        rooms.add(r);
    }

    public void listAllRooms() {
        System.out.println("=== All rooms ===");
        for (Room r : rooms) {
            r.displayInfo();
        }
    }

    public void listAvailableRooms() {
        System.out.println("=== Available rooms ===");
        boolean found = false;
        for (Room r : rooms) {
            if (!r.isBooked()) {
                r.displayInfo();
                found = true;
            }
        }
        if (!found) System.out.println("No available rooms right now.");
    }

    public Booking findBookingByRoomNumber(int roomNumber) {
        for (Booking b : bookings) {
            if (b.getRoomNumber() == roomNumber) return b;
        }
        return null;
    }

    public boolean bookRoom(Guest guest, int roomNumber, int nights) {
        for (Room r : rooms) {
            if (r.getRoomNumber() == roomNumber) {
                if (r.isBooked()) {
                    System.out.println("Room is already booked.");
                    return false;
                } else {
                    r.book();
                    Booking b = new Booking(guest, r, nights);
                    bookings.add(b);
                    System.out.println("Booking successful. Booking ID: " + b.getBookingId());
                    System.out.printf("Total to pay: $%.2f\n", b.getTotalPrice());
                    return true;
                }
            }
        }
        System.out.println("Room not found.");
        return false;
    }

    public boolean cancelBookingByRoom(int roomNumber) {
        Iterator<Booking> it = bookings.iterator();
        while (it.hasNext()) {
            Booking b = it.next();
            if (b.getRoomNumber() == roomNumber) {
                // free the room
                for (Room r : rooms) {
                    if (r.getRoomNumber() == roomNumber) {
                        r.cancel();
                        break;
                    }
                }
                it.remove();
                System.out.println("Booking cancelled for room " + roomNumber);
                return true;
            }
        }
        System.out.println("No booking found for room " + roomNumber);
        return false;
    }

    public void listBookings() {
        System.out.println("=== Current bookings ===");
        if (bookings.isEmpty()) {
            System.out.println("No bookings.");
            return;
        }
        for (Booking b : bookings) {
            b.displayBooking();
            System.out.println("---------------------");
        }
    }
}

// Main app with simple console menu
public class HotelApp {
    public static void main(String[] args) {
        BookingSystem system = new BookingSystem();

‎        // إضافة غرف تجريبية
        system.addRoom(new SingleRoom(101, 50));
        system.addRoom(new SingleRoom(102, 55));
        system.addRoom(new DoubleRoom(201, 80));
        system.addRoom(new DoubleRoom(202, 85));
        system.addRoom(new SuiteRoom(301, 150));
        system.addRoom(new SuiteRoom(302, 180));

        Scanner sc = new Scanner(System.in);
        boolean running = true;

        System.out.println("Welcome to Simple Hotel Booking System!");

        while (running) {
            System.out.println("\nMenu:");
            System.out.println("1. List all rooms");
            System.out.println("2. List available rooms");
            System.out.println("3. Book a room");
            System.out.println("4. Cancel booking by room number");
            System.out.println("5. List bookings");
            System.out.println("6. Exit");
            System.out.print("Choose option: ");
            String opt = sc.nextLine();

            switch (opt) {
                case "1":
                    system.listAllRooms();
                    break;
                case "2":
                    system.listAvailableRooms();
                    break;
                case "3":
                    System.out.print("Guest name: ");
                    String name = sc.nextLine();
                    System.out.print("Guest ID: ");
                    String id = sc.nextLine();
                    System.out.print("Room number to book: ");
                    int roomNum;
                    try {
                        roomNum = Integer.parseInt(sc.nextLine());
                    } catch (NumberFormatException e) {
                        System.out.println("Invalid room number.");
                        break;
                    }
                    System.out.print("Number of nights: ");
                    int nights;
                    try {
                        nights = Integer.parseInt(sc.nextLine());
                    } catch (NumberFormatException e) {
                        System.out.println("Invalid nights.");
                        break;
                    }
                    Guest g = new Guest(name, id);
                    system.bookRoom(g, roomNum, nights);
                    break;
                case "4":
                    System.out.print("Room number to cancel booking: ");
                    try {
                        int rnum = Integer.parseInt(sc.nextLine());
                        system.cancelBookingByRoom(rnum);
                    } catch (NumberFormatException e) {
                        System.out.println("Invalid room number.");
                    }
                    break;
                case "5":
                    system.listBookings();
                    break;
                case "6":
                    running = false;
                    break;
                default:
                    System.out.println("Invalid option. Try again.");
            }
        }

        System.out.println("Goodbye!");
        sc.close();
    }
}
